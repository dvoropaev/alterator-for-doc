#: ../apt/apt-wrapper:95
msgid ""
"The wrong number of arguments was passed to create the pkgpriorities file"
msgstr "Передано неверное количество аргументов для создания файла pkgpriorities"

#: ../apt/apt-wrapper:101
msgid "Error creating temporary pkgpriorities file"
msgstr "Ошибка создания временного файла pkgpriorities"

#: ../apt/apt-wrapper:114
msgid "Failed to populate the pkgpriorities file with data"
msgstr "Не удалось записать данные в файл pkgpriorities"

#: ../apt/apt-wrapper:122
msgid "Preparing the transaction..."
msgstr "Подготовка транзакции..."

#: ../apt/apt-wrapper:101
msgid "Error: cdrom: repository is configured, but required installation media is not available."
msgstr "Ошибка: настроен cdrom-репозиторий, но требуемый установочный носитель недоступен."

#: ../apt/apt-wrapper:102
msgid "Configured media labels:"
msgstr "Метки носителей:"

#: ../apt/apt-wrapper:104
msgid "Fix:"
msgstr "Как исправить:"

#: ../apt/apt-wrapper:105
msgid "  - mount the installation medium/ISO and retry or"
msgstr "  - смонтируйте установочный носитель/ISO и повторите попытку или"

#: ../apt/apt-wrapper:106
msgid "  - replace cdrom sources with an online repository."
msgstr "  - замените cdrom-источники на сетевой репозиторий."
